<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@ViewData["Title"] - ZKBIO Dashboard</title>
  <link rel="icon" type="image/png" href="~/images/logo/jhv-Photoroom.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <!-- Theme style -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
  <!-- Local overrides -->
  <link rel="stylesheet" href="~/css/site.css">
  <!-- Flatpickr -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <style>
    /* ---- Top progress bar ---- */
    #top-progress-bar {
        position: fixed; top: 0; left: 0;
        width: 0%; height: 3px;
        background: linear-gradient(90deg, #15803d, #22c55e);
        z-index: 9999;
        transition: width 0.3s ease-in-out;
        box-shadow: 0 0 16px rgba(21, 128, 61, 0.45);
        pointer-events: none;
    }
    @@keyframes pulse-progress {
        0%,100% { opacity: 0.6; }
        50%      { opacity: 1; }
    }
    #top-progress-bar.loading { animation: pulse-progress 1.5s infinite ease-in-out; }

    /* ---- Content header ---- */
    .content-header h1 { font-size: 1.25rem; font-weight: 800; color: #0f172a; letter-spacing: -0.03em; }

    /* ---- Skeleton loader (shared across pages) ---- */
    .skeleton {
        background: linear-gradient(110deg, #ececec 8%, #f5f5f5 18%, #ececec 33%);
        border-radius: 4px;
        background-size: 200% 100%;
        animation: 1.5s shine linear infinite;
    }
    .skeleton-text { height: 18px; width: 100%; margin-bottom: 5px; }
    @@keyframes shine { to { background-position-x: -200%; } }

    #skeleton-loader { display: none; }
    body.is-loading #skeleton-loader { display: table-row-group; }
    body.is-loading #table-data     { display: none; }
    body.is-loading .pagination     { pointer-events: none; opacity: 0.6; }
  </style>
  @RenderSection("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini sidebar-no-expand app-shell">
<div id="top-progress-bar"></div>
<div class="wrapper">

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light app-topbar">
    <!-- Left navbar links -->
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
      </li>
    </ul>

    <!-- Right navbar links -->
    <ul class="navbar-nav ml-auto">
      <li class="nav-item">
        <span class="nav-link app-user-greeting">Welcome, @User.Identity?.Name</span>
      </li>
      <li class="nav-item">
        <a class="nav-link" asp-page="/Logout" role="button">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </li>
    </ul>
  </nav>
  <!-- /.navbar -->

  <!-- Main Sidebar Container -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4 app-sidebar">
    <!-- Brand Logo -->
    <a href="/" class="brand-link text-center px-0 py-1 app-brand-link" style="display: flex; justify-content: center; align-items: center; min-height: 56px;">
      <!-- Expanded Logo (Full) -->
      <img src="/images/logo/logo6600_oversea.png"
           alt="ZKBIO Logo" 
           id="sidebarLogoExpanded"
           class="logo-xl"
           style="max-height: 40px; width: auto;">
      
      <!-- Collapsed Logo (Compact) -->
      <img src="/images/logo/favicon_cv.png"
           alt="ZKBIO Logo" 
           id="sidebarLogoCollapsed"
           class="logo-xs"
           style="max-height: 33px; width: auto;">
    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar Menu -->
      <nav class="mt-2">
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
          <li class="nav-item">
            <a asp-page="/AllTransaction" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/AllTransaction" ? "active" : "")">
              <i class="nav-icon fas fa-exchange-alt"></i>
              <p>All Transactions</p>
            </a>
          </li>
          <li class="nav-item">
            <a asp-page="/AttendanceReport" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/AttendanceReport" ? "active" : "")">
              <i class="nav-icon fas fa-exclamation-triangle"></i>
              <p>Abnormal Transactions</p>
            </a>
          </li>
          <li class="nav-item">
            <a asp-page="/EarlyExitReport" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/EarlyExitReport" ? "active" : "")">
              <i class="nav-icon fas fa-sign-out-alt"></i>
              <p>Early Exit</p>
            </a>
          </li>
          <li class="nav-item">
            <a asp-page="/ContractorAttendance" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/ContractorAttendance" ? "active" : "")">
              <i class="nav-icon fas fa-hard-hat"></i>
              <p>Contractor Access History</p>
            </a>
          </li>
          <li class="nav-item">
            <a asp-page="/PersonalAttendance" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/PersonalAttendance" ? "active" : "")">
              <i class="nav-icon fas fa-user-clock"></i>
              <p>Personnel Access History</p>
            </a>
          </li>
        </ul>
      </nav>
      <!-- /.sidebar-menu -->
    </div>
    <!-- /.sidebar -->
  </aside>

  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper app-content-wrapper">
    @RenderBody()
  </div>
  <!-- /.content-wrapper -->

</div>
<!-- ./wrapper -->

<!-- jQuery -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<!-- Bootstrap 4 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.1/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE App -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<!-- Flatpickr -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    $(document).ready(function() {
        // Flatpickr for datetime-local inputs
        $('input[type="datetime-local"]').each(function() {
            $(this).flatpickr({
                enableTime: true, time_24hr: true,
                dateFormat: "Y-m-d H:i:S", enableSeconds: true, allowInput: true,
                onReady: function(_, __, instance) { $(instance.element).attr('type', 'text'); }
            });
        });

        // Flatpickr for date inputs
        $('input[type="date"]').each(function() {
            $(this).flatpickr({
                dateFormat: "Y-m-d", allowInput: true,
                onReady: function(_, __, instance) { $(instance.element).attr('type', 'text'); }
            });
        });

        // Top progress bar on navigation
        $('.nav-link, .brand-link, .page-link').on('click', function(e) {
            var href = $(this).attr('href');
            if (href && href !== '#' && !e.ctrlKey && !e.shiftKey && !e.metaKey && this.hostname === window.location.hostname) {
                $('#top-progress-bar').addClass('loading').css('width', '50%');
                setTimeout(function() { $('#top-progress-bar').css('width', '80%'); }, 500);
            }
        });

        $(window).on('load', function() {
            $('#top-progress-bar').css('width', '100%');
            setTimeout(function() {
                $('#top-progress-bar').removeClass('loading').css('opacity', '0');
                setTimeout(function() { $('#top-progress-bar').css('width', '0').css('opacity', '1'); }, 300);
            }, 300);
        });

        // PIN auto-format: strip spaces and uppercase (shared across all pages)
        $(document).on('input change blur', '[name="Pin"], [name="Filter.Pin"]', function() {
            var pos = this.selectionStart;
            $(this).val($(this).val().replace(/\s+/g, '').toUpperCase());
            this.selectionStart = this.selectionEnd = pos;
        });

        // Skeleton loading on form submit and pagination clicks
        $('form').not('#exportForm').on('submit', function() {
            $('body').addClass('is-loading');
        });
        $(document).on('click', '.page-link', function() {
            if (!$(this).parent().hasClass('disabled') && !$(this).parent().hasClass('active')) {
                $('body').addClass('is-loading');
            }
        });

        function parseSortableValue(raw) {
            var value = (raw || '').trim();
            if (!value || value === '-') return { empty: true, type: 'empty', val: '' };

            if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
                return { empty: false, type: 'date', val: Date.parse(value + 'T00:00:00') };
            }
            if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}:\d{2}$/.test(value)) {
                return { empty: false, type: 'date', val: Date.parse(value.replace(' ', 'T')) };
            }
            if (/^\d{2}:\d{2}:\d{2}$/.test(value)) {
                var parts = value.split(':');
                return { empty: false, type: 'time', val: (+parts[0]) * 3600 + (+parts[1]) * 60 + (+parts[2]) };
            }

            var numeric = Number(value.replace(/,/g, ''));
            if (!Number.isNaN(numeric) && value.match(/^-?[\d,.]+$/)) {
                return { empty: false, type: 'number', val: numeric };
            }

            return { empty: false, type: 'text', val: value.toLowerCase() };
        }

        function compareSortable(a, b, asc) {
            if (a.empty && b.empty) return 0;
            if (a.empty) return 1;
            if (b.empty) return -1;

            if (a.type === b.type && (a.type === 'number' || a.type === 'date' || a.type === 'time')) {
                return asc ? a.val - b.val : b.val - a.val;
            }

            var textCompare = String(a.val).localeCompare(String(b.val), undefined, { numeric: true, sensitivity: 'base' });
            return asc ? textCompare : -textCompare;
        }

        function initSystemTableSort() {
            $('.js-sortable-table').each(function() {
                var $table = $(this);
                if ($table.data('sortInit')) return;
                $table.data('sortInit', true);

                var $headers = $table.find('thead th');
                $headers.addClass('sortable-header').attr('data-sort-state', 'none');

                var currentIndex = -1;
                var asc = true;

                $headers.on('click', function() {
                    var $header = $(this);
                    var index = $header.index();
                    asc = currentIndex === index ? !asc : true;
                    currentIndex = index;

                    $headers.attr('data-sort-state', 'none');
                    $header.attr('data-sort-state', asc ? 'asc' : 'desc');

                    var $tbody = $table.find('tbody#table-data');
                    if ($tbody.length === 0) {
                        $tbody = $table.find('tbody').first();
                    }

                    var rows = $tbody.find('tr').toArray();
                    rows.sort(function(rowA, rowB) {
                        var aRaw = $(rowA).children().eq(index).text();
                        var bRaw = $(rowB).children().eq(index).text();
                        return compareSortable(parseSortableValue(aRaw), parseSortableValue(bRaw), asc);
                    });
                    $tbody.append(rows);
                });
            });
        }

        function syncSidebarBrandLogo() {
            var collapsed = $('body').hasClass('sidebar-collapse');
            if (collapsed) {
                $('#sidebarLogoExpanded').hide();
                $('#sidebarLogoCollapsed').show();
            } else {
                $('#sidebarLogoExpanded').show();
                $('#sidebarLogoCollapsed').hide();
            }
        }

        syncSidebarBrandLogo();
        $(document).on('click', '[data-widget="pushmenu"]', function() {
            setTimeout(syncSidebarBrandLogo, 20);
            setTimeout(syncSidebarBrandLogo, 180);
        });
        $(window).on('resize', function() {
            setTimeout(syncSidebarBrandLogo, 20);
        });

        initSystemTableSort();
    });
</script>
@RenderSection("Scripts", required: false)
</body>
</html>

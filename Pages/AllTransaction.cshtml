@page "/all-transactions"
@model ZkbioDashboard.Pages.AllTransactionModel
@{
    ViewData["Title"] = "All Transactions";
}



<section class="content alltx-shell" style="padding:0;">
    <div class="container-fluid px-0 d-flex flex-column" style="height:calc(100vh - 57px); overflow:hidden; gap:0;">

        <div class="at-page-header">
            <h1>All Transactions</h1>
        </div>

        <!-- Filter -->
        <div class="at-filter-card">
            <div class="at-filter-body">
                <form method="get" id="filterForm">
                    <!-- Preset date range pills -->
                    <div class="at-preset-row">
                        <span class="at-preset" data-preset="today">Today</span>
                        <span class="at-preset" data-preset="yesterday">Yesterday</span>
                        <span class="at-preset" data-preset="7days">Last 7 days</span>
                        <span class="at-preset" data-preset="thismonth">This month</span>
                        <span class="at-preset" data-preset="lastmonth">Last month</span>
                    </div>
                    <div class="at-filter-grid">
                        <div>
                            <label>From</label>
                            <input type="datetime-local" asp-for="Filter.FromDate" class="form-control" step="1" />
                        </div>
                        <div>
                            <label>To</label>
                            <input type="datetime-local" asp-for="Filter.ToDate" class="form-control" step="1" />
                        </div>
                        <div>
                            <label>Factory</label>
                            <select asp-for="Filter.AreaName" class="form-control">
                                <option value="">-- All --</option>
                                @foreach (var factory in Model.Factories)
                                {
                                    <option value="@factory">@factory</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Dept</label>
                            <input type="text" asp-for="Filter.DeptName" class="form-control" />
                        </div>
                        <div>
                            <label>PIN</label>
                            <input type="text" asp-for="Filter.Pin" class="form-control" />
                        </div>
                        <div>
                            <label>Name</label>
                            <input type="text" asp-for="Filter.Name" class="form-control" />
                        </div>
                        <div>
                            <label>Device</label>
                            <input type="text" asp-for="Filter.DevAlias" class="form-control" />
                        </div>
                        <div>
                            <label>Status</label>
                            <select asp-for="Filter.Status" class="form-control">
                                <option value="">All</option>
                                <option value="Normal">Normal</option>
                                <option value="Exception">Exception</option>
                            </select>
                        </div>
                        <div class="at-filter-actions">
                            <button type="submit" class="at-btn at-btn-primary" title="Apply Filters">
                                <i class="fas fa-search"></i>
                            </button>
                            <div class="at-export-wrap">
                                <button type="button" class="at-btn at-btn-secondary" id="btnExportToggle" title="Export">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="at-export-menu" id="exportMenuDropdown">
                                    <a href="javascript:void(0)" onclick="openExportModal('excel')">
                                        <i class="far fa-file-excel" style="color:#16a34a;"></i> Excel
                                    </a>
                                    <a href="javascript:void(0)" onclick="openExportModal('pdf')">
                                        <i class="far fa-file-pdf" style="color:#dc2626;"></i> PDF
                                    </a>
                                </div>
                            </div>
                            <a asp-page="./AllTransaction" class="at-btn at-btn-ghost" title="Reset">
                                <i class="fas fa-undo-alt"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Export Modal -->
        <div class="modal fade" id="exportModal" tabindex="-1" role="dialog" aria-labelledby="exportModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content" style="border-radius:18px; overflow:hidden; border:1px solid #dbe3ee; box-shadow:0 20px 50px rgba(15,23,42,0.15);">
                    <form id="exportForm" method="post" action="">
                        <div class="modal-header" style="border-bottom:1px solid #f1f5f9; padding:16px 20px;">
                            <h5 class="modal-title" id="exportModalLabel" style="font-size:0.95rem; font-weight:700; color:#0f172a;">Select Columns to Export</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body" style="padding:16px 20px;">
                            <input type="hidden" name="FromDate"   id="exportFromDate" />
                            <input type="hidden" name="ToDate"     id="exportToDate" />
                            <input type="hidden" name="AreaName"   id="exportAreaName" />
                            <input type="hidden" name="DeptName"   id="exportDeptName" />
                            <input type="hidden" name="Pin"        id="exportPin" />
                            <input type="hidden" name="Name"       id="exportName" />
                            <input type="hidden" name="DevAlias"   id="exportDevAlias" />
                            <input type="hidden" name="EventPoint" id="exportEventPoint" />
                            <input type="hidden" name="Status"     id="exportStatus" />

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="selectAllColumns" checked>
                                <label class="form-check-label" style="font-weight:700; font-size:0.83rem;" for="selectAllColumns">Select All</label>
                            </div>
                            <hr style="margin:8px 0;" />
                            <div class="row" style="row-gap:4px;">
                                @{
                                    var columns = new[] {
                                        ("Time",             "Time"),
                                        ("Area Name",        "Factory"),
                                        ("Dept Name",        "Dept"),
                                        ("PIN",              "PIN"),
                                        ("Name",             "Name"),
                                        ("Device Alias",     "Device"),
                                        ("Event Point Name", "Event Point"),
                                        ("Status",           "Status"),
                                        ("Verify Mode",      "Verify"),
                                    };
                                    foreach (var (val, lbl) in columns)
                                    {
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input column-checkbox" type="checkbox" name="selectedColumns" value="@val" id="col_@val.Replace(" ", "")" checked>
                                                <label class="form-check-label" style="font-size:0.82rem;" for="col_@val.Replace(" ", "")">@lbl</label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <div class="modal-footer" style="border-top:1px solid #f1f5f9; padding:12px 20px; gap:8px;">
                            <button type="button" class="at-btn at-btn-ghost" data-dismiss="modal">Cancel</button>
                            <button type="submit" class="at-btn at-btn-primary" id="btnConfirmExport">
                                <i class="fas fa-download"></i> Download
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="at-table-card flex-fill" style="margin-bottom:0; min-height:0;">
            <div class="at-table-scroll">
                <table id="transactionTable" class="at-table js-sortable-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Factory</th>
                            <th>Dept</th>
                            <th>PIN</th>
                            <th>Name</th>
                            <th>Device</th>
                            <th>Event Point</th>
                            <th>Status</th>
                            <th>Verify</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Transactions != null)
                        {
                            foreach (var item in Model.Transactions)
                            {
                                <tr>
                                    <td>@item.EventTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@item.AreaName</td>
                                    <td>@item.DeptName</td>
                                    <td>@item.Pin</td>
                                    <td>@item.FullName</td>
                                    <td>@item.DevAlias</td>
                                    <td>@item.EventPointName</td>
                                    <td>
                                        @if (item.Status == "Normal")
                                        {
                                            <span class="at-badge at-badge-ok">Normal</span>
                                        }
                                        else if (item.Status == "Exception")
                                        {
                                            <span class="at-badge at-badge-err">Exception</span>
                                        }
                                        else
                                        {
                                            <span class="at-badge at-badge-mute">@item.Status</span>
                                        }
                                    </td>
                                    <td>@item.VerifyModeDisplay</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="at-empty">No data found or connection error.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="at-footer">
                <ul class="at-pagination">
                    <li style="display:flex;align-items:center;padding:0 8px;">
                        <span class="at-footer-total">@Model.TotalCount.ToString("N0") records</span>
                    </li>
                    <li class="@(Model.PageNumber == 1 ? "disabled" : "")">
                        <a asp-page="./AllTransaction"
                           asp-route-PageNumber="@(Model.PageNumber - 1)"
                           asp-route-Filter.FromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-ddTHH:mm")"
                           asp-route-Filter.ToDate="@Model.Filter.ToDate?.ToString("yyyy-MM-ddTHH:mm")"
                           asp-route-Filter.AreaName="@Model.Filter.AreaName"
                           asp-route-Filter.DeptName="@Model.Filter.DeptName"
                           asp-route-Filter.Pin="@Model.Filter.Pin"
                           asp-route-Filter.Name="@Model.Filter.Name"
                           asp-route-Filter.DevAlias="@Model.Filter.DevAlias"
                           asp-route-Filter.EventPoint="@Model.Filter.EventPoint"
                           asp-route-Filter.Status="@Model.Filter.Status">&laquo;</a>
                    </li>
                    @for (int i = Math.Max(1, Model.PageNumber - 5); i <= Math.Min(Model.TotalPages, Model.PageNumber + 5); i++)
                    {
                        <li class="@(i == Model.PageNumber ? "active" : "")">
                            <a asp-page="./AllTransaction"
                               asp-route-PageNumber="@i"
                               asp-route-Filter.FromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-ddTHH:mm")"
                               asp-route-Filter.ToDate="@Model.Filter.ToDate?.ToString("yyyy-MM-ddTHH:mm")"
                               asp-route-Filter.AreaName="@Model.Filter.AreaName"
                               asp-route-Filter.DeptName="@Model.Filter.DeptName"
                               asp-route-Filter.Pin="@Model.Filter.Pin"
                               asp-route-Filter.Name="@Model.Filter.Name"
                               asp-route-Filter.DevAlias="@Model.Filter.DevAlias"
                               asp-route-Filter.EventPoint="@Model.Filter.EventPoint"
                               asp-route-Filter.Status="@Model.Filter.Status">@i</a>
                        </li>
                    }
                    <li class="@(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                        <a asp-page="./AllTransaction"
                           asp-route-PageNumber="@(Model.PageNumber + 1)"
                           asp-route-Filter.FromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-ddTHH:mm")"
                           asp-route-Filter.ToDate="@Model.Filter.ToDate?.ToString("yyyy-MM-ddTHH:mm")"
                           asp-route-Filter.AreaName="@Model.Filter.AreaName"
                           asp-route-Filter.DeptName="@Model.Filter.DeptName"
                           asp-route-Filter.Pin="@Model.Filter.Pin"
                           asp-route-Filter.Name="@Model.Filter.Name"
                           asp-route-Filter.DevAlias="@Model.Filter.DevAlias"
                           asp-route-Filter.EventPoint="@Model.Filter.EventPoint"
                           asp-route-Filter.Status="@Model.Filter.Status">&raquo;</a>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            ZKBioUi.initSelectAllCheckbox('#selectAllColumns', '.column-checkbox');
            ZKBioUi.initSimpleDropdown('#btnExportToggle', '#exportMenuDropdown');

            ZKBioUi.initDatePresetRange({
                presetSelector: '.at-preset',
                fromSelector: '[name="Filter.FromDate"]',
                toSelector: '[name="Filter.ToDate"]',
                formSelector: '#filterForm',
                submitDelayMs: 80
            });
        });

        function openExportModal(type) {
            $('#exportFromDate').val($('[name="Filter.FromDate"]').val());
            $('#exportToDate').val($('[name="Filter.ToDate"]').val());
            $('#exportAreaName').val($('[name="Filter.AreaName"]').val());
            $('#exportDeptName').val($('[name="Filter.DeptName"]').val());
            $('#exportPin').val($('[name="Filter.Pin"]').val());
            $('#exportName').val($('[name="Filter.Name"]').val());
            $('#exportDevAlias').val($('[name="Filter.DevAlias"]').val());
            $('#exportEventPoint').val($('[name="Filter.EventPoint"]').val());
            $('#exportStatus').val($('[name="Filter.Status"]').val());
            $('#exportForm').attr('action', '/api/export/' + type);
            $('#exportModalLabel').text('Export — ' + type.toUpperCase());
            $('#exportMenuDropdown').removeClass('open');
            $('#exportModal').modal('show');
        }
    </script>
}

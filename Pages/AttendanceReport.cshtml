@page "/abnormal-transactions"
@model ZkbioDashboard.Pages.AttendanceReportModel
@{
    ViewData["Title"] = "Abnormal Transactions";
}

@section Scripts {
    <script>
        function viewDetails(pin, first, last, name) {
            ZKBioUi.openTransactionDetails({
                employeeHeader: name + ' (' + pin + ')',
                dateHeader: '',
                url: '?handler=Details',
                requestData: { pin: pin, start: first, end: last },
                noRecordsText: 'No records found.',
                errorText: 'Error fetching details.'
            });
        }

        $(function () {
            ZKBioUi.initSelectAllCheckbox('#selectAllColumns', '.column-checkbox');

            ZKBioUi.initTypeMultiSelect({
                buttonSelector: '#typeDropdownBtn',
                menuSelector: '#typeDropdownMenu',
                checkboxSelector: '[name="SelectedTypes"]',
                emptyText: '-- All --',
                labelBuilder: function ($checkbox) {
                    return $checkbox.next('label').text();
                }
            });

            ZKBioUi.initSimpleDropdown('#btnExportToggle', '#exportMenuDropdown');
        });

        function openExportModal(type) {
            $('#exportDate')   .val($('[name="ReportDate"]').val());
            $('#exportFactory').val($('[name="Factory"]').val());
            $('#exportBU')     .val($('[name="BU"]').val());
            $('#exportPin')    .val($('[name="Pin"]').val());

            $('#exportSelectedTypesContainer').empty();
            $('[name="SelectedTypes"]:checked').each(function() {
                $('<input type="hidden" name="selectedTypes">').val($(this).val()).appendTo('#exportSelectedTypesContainer');
            });

            $('#exportForm').attr('action', '/api/export/attendance/' + type);
            $('#exportModalLabel').text('Export — ' + type.toUpperCase());
            $('#exportMenuDropdown').removeClass('open');
            $('#exportModal').modal('show');
        }
    </script>
}

<section class="content report-shell" style="padding:0; --at-filter-col-min: 150px;">
    <div class="container-fluid px-0 d-flex flex-column" style="height:calc(100vh - 57px); overflow:hidden; gap:0;">

        <div class="at-page-header">
            <h1>Abnormal Transactions</h1>
        </div>

        <div class="at-filter-card">
            <div class="at-filter-body">
                <form method="get">
                    <div class="at-filter-grid">
                        <div>
                            <label>Date</label>
                            <input type="date" asp-for="ReportDate" class="form-control" />
                        </div>
                        <div>
                        <label>Factory</label>
                            <select asp-for="Factory" class="form-control">
                                <option value="">-- All --</option>
                                @foreach (var factory in Model.Factories)
                                {
                                    <option value="@factory">@factory</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>BU</label>
                            <select asp-for="BU" class="form-control">
                                <option value="">-- All --</option>
                                @foreach (var bu in Model.BUs)
                                {
                                    <option value="@bu">@bu</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Type</label>
                            <div class="at-type-dropdown">
                                <button type="button" class="at-type-btn" id="typeDropdownBtn">-- All --</button>
                                <div class="at-type-menu" id="typeDropdownMenu">
                                    @foreach (var type in Model.Types)
                                    {
                                        <div class="custom-control custom-checkbox small mb-1">
                                            <input class="custom-control-input" type="checkbox" name="SelectedTypes" value="@type" id="type_@type" @(Model.SelectedTypes.Contains(type) ? "checked" : "")>
                                            <label class="custom-control-label" for="type_@type">@Model.GetTypeLabel(type)</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div>
                            <label>PIN</label>
                            <input type="text" asp-for="Pin" class="form-control" placeholder="Search PIN..." />
                        </div>
                        <div class="at-filter-actions">
                            <button type="submit" class="at-btn at-btn-primary" title="Apply">
                                <i class="fas fa-search"></i>
                            </button>
                            <div class="at-export-wrap">
                                <button type="button" class="at-btn at-btn-secondary" id="btnExportToggle" title="Export">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="at-export-menu" id="exportMenuDropdown">
                                    <a href="javascript:void(0)" onclick="openExportModal('excel')">
                                        <i class="far fa-file-excel" style="color:#16a34a;"></i> Excel
                                    </a>
                                    <a href="javascript:void(0)" onclick="openExportModal('pdf')">
                                        <i class="far fa-file-pdf" style="color:#dc2626;"></i> PDF
                                    </a>
                                </div>
                            </div>
                            <a asp-page="./AttendanceReport" class="at-btn at-btn-ghost" title="Reset">
                                <i class="fas fa-undo-alt"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
            <div class="at-legend">
                <span><b>[B]</b> Missing 2+2 records</span>
                <span><b>[C1]</b> Gate Entry 30m Early</span>
                <span><b>[C2]</b> Gate Exit &gt; 30m after Attend Out</span>
                <span><b>[D1]</b> Late Arrival</span>
                <span><b>[D2]</b> Early Departure</span>
            </div>
        </div>

        <!-- Export Modal -->
        <div class="modal fade" id="exportModal" tabindex="-1" role="dialog" aria-labelledby="exportModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content" style="border-radius:18px; overflow:hidden; border:1px solid #dbe3ee; box-shadow:0 20px 50px rgba(15,23,42,0.15);">
                    <form id="exportForm" method="post" action="">
                        <div class="modal-header" style="border-bottom:1px solid #f1f5f9; padding:16px 20px;">
                            <h5 class="modal-title" id="exportModalLabel" style="font-size:0.95rem; font-weight:700; color:#0f172a;">Select Columns to Export</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="modal-body" style="padding:16px 20px;">
                            <input type="hidden" name="date"    id="exportDate" />
                            <input type="hidden" name="factory" id="exportFactory" />
                            <input type="hidden" name="bu"      id="exportBU" />
                            <input type="hidden" name="pin"     id="exportPin" />
                            <div id="exportSelectedTypesContainer" style="display:none"></div>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="selectAllColumns" checked>
                                <label class="form-check-label" style="font-weight:700; font-size:0.83rem;" for="selectAllColumns">Select All</label>
                            </div>
                            <hr style="margin:8px 0;" />
                            <div class="row" style="row-gap:4px;">
                                @{
                                    var attCols = new[] {
                                        ("Factory",   "Factory"),
                                        ("BU",        "BU"),
                                        ("Dept Name", "Dept"),
                                        ("PIN",       "PIN"),
                                        ("Name",      "Name"),
                                        ("Type",      "Type"),
                                        ("Shift Date","Shift Date"),
                                        ("Gate In",   "Gate In"),
                                        ("Attend In", "Attend In"),
                                        ("Attend Out","Attend Out"),
                                        ("Gate Out (ACS)", "Gate Out"),
                                    };
                                    foreach (var (val, lbl) in attCols)
                                    {
                                        var colId = "att_" + val.Replace(" ", "").Replace("(", "").Replace(")", "");
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input column-checkbox" type="checkbox" name="selectedColumns" value="@val" id="@colId" checked>
                                                <label class="form-check-label" style="font-size:0.82rem;" for="@colId">@lbl</label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <div class="modal-footer" style="border-top:1px solid #f1f5f9; padding:12px 20px; gap:8px;">
                            <button type="button" class="at-btn at-btn-ghost" data-dismiss="modal">Cancel</button>
                            <button type="submit" class="at-btn at-btn-primary"><i class="fas fa-download"></i> Download</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="at-table-card">
            <div class="at-table-scroll">
                <table class="at-table js-sortable-table">
                    <thead>
                        <tr>
                            <th>Factory</th>
                            <th>BU</th>
                            <th>Dept</th>
                            <th>PIN</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Shift Date</th>
                            <th>Gate In</th>
                            <th>Attend In</th>
                            <th>Attend Out</th>
                            <th>Gate Out</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="skeleton-loader">
                        @for (int i = 0; i < 18; i++)
                        {
                            <tr>
                                <td><div class="skeleton skeleton-text" style="width:80px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:60px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:120px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:70px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:150px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:40px"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:90px"></div></td>
                                <td><div class="skeleton skeleton-text"></div></td>
                                <td><div class="skeleton skeleton-text"></div></td>
                                <td><div class="skeleton skeleton-text"></div></td>
                                <td><div class="skeleton skeleton-text"></div></td>
                                <td><div class="skeleton skeleton-text" style="width:70px"></div></td>
                            </tr>
                        }
                    </tbody>
                    <tbody id="table-data">
                        @if (Model.Records != null && Model.Records.Any())
                        {
                            foreach (var item in Model.Records)
                            {
                                <tr>
                                    <td>@item.Factory</td>
                                    <td>@item.BU</td>
                                    <td>@item.DeptName</td>
                                    <td>@item.Pin</td>
                                    <td>@item.FullName</td>
                                    <td>@ZkbioDashboard.Helpers.AttendanceFilterHelper.FormatEffectiveType(item)</td>
                                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@(item.GateIn?.ToString("HH:mm:ss") ?? "-")</td>
                                    <td>@(item.AttendIn?.ToString("HH:mm:ss") ?? "-")</td>
                                    <td>@(item.AttendOut?.ToString("HH:mm:ss") ?? "-")</td>
                                    <td>@(item.GateOut?.ToString("HH:mm:ss") ?? "-")</td>
                                    <td>
                                        @if (item.FirstPunch.HasValue && item.LastPunch.HasValue)
                                        {
                                            <button type="button" class="at-btn-detail"
                                                    onclick="viewDetails('@item.Pin', '@item.FirstPunch.Value.ToString("yyyy-MM-ddTHH:mm:ss")', '@item.LastPunch.Value.ToString("yyyy-MM-ddTHH:mm:ss")', '@item.FullName')">
                                                Details
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="12" class="at-empty">No data found for the selected date.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="at-footer">
                <ul class="at-pagination">
                    <li style="display:flex;align-items:center;padding:0 8px;">
                        <span class="at-footer-total">@Model.TotalCount.ToString("N0") records</span>
                    </li>
                    @{
                        var baseRoute = new Dictionary<string, string> {
                            { "ReportDate", Model.ReportDate?.ToString("yyyy-MM-dd") ?? "" },
                            { "Factory",   Model.Factory ?? "" },
                            { "BU",        Model.BU ?? "" },
                            { "Pin",       Model.Pin ?? "" }
                        };
                        for (int idx = 0; idx < Model.SelectedTypes.Count; idx++)
                        {
                            baseRoute[$"SelectedTypes[{idx}]"] = Model.SelectedTypes[idx];
                        }
                    }
                    <li class="@(Model.PageNumber <= 1 ? "disabled" : "")">
                        @{ var prevRoute = new Dictionary<string, string>(baseRoute); prevRoute["PageNumber"] = (Model.PageNumber - 1).ToString(); }
                        <a asp-page="./AttendanceReport" asp-all-route-data="prevRoute">&laquo;</a>
                    </li>
                    @for (int i = Math.Max(1, Model.PageNumber - 5); i <= Math.Min(Model.TotalPages, Model.PageNumber + 5); i++)
                    {
                        <li class="@(i == Model.PageNumber ? "active" : "")">
                            @{ var currRoute = new Dictionary<string, string>(baseRoute); currRoute["PageNumber"] = i.ToString(); }
                            <a asp-page="./AttendanceReport" asp-all-route-data="currRoute">@i</a>
                        </li>
                    }
                    <li class="@(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        @{ var nextRoute = new Dictionary<string, string>(baseRoute); nextRoute["PageNumber"] = (Model.PageNumber + 1).ToString(); }
                        <a asp-page="./AttendanceReport" asp-all-route-data="nextRoute">&raquo;</a>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</section>

@await Html.PartialAsync("_TransactionDetailsModal")


@page
@model ZkbioDashboard.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Log in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ZKBIO CVSecurity | Log in</title>
    <link rel="icon" type="image/png" href="~/images/logo/favicon_cv.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body class="login-page">
    <main class="login-shell">
        <section class="login-stage">
            <div class="login-brand-panel">
                <div class="login-brand-mark">
                    <img src="~/images/logo/logo6600_oversea.png" alt="ZKBIO CVSecurity">
                </div>

                <div class="login-brand-visual">
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-brand-icon">
                        <img src="~/images/logo/favicon_cv.png" alt="" style="width:38px;height:38px;object-fit:contain;">
                    </div>
                </div>

                <div class="login-brand-footer">
                    <span>Access Control</span>
                    <span class="dot"></span>
                    <span>Attendance</span>
                </div>

                <div class="login-brand-badge">
                    <img src="~/images/logo/jhv-Photoroom.png" alt="JHV">
                </div>
            </div>

            <div class="login-form-panel">
                <div class="login-form-card">
                    <h2>Sign in</h2>

                    <form method="post">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="login-alert">@Model.ErrorMessage</div>
                        }

                        <div class="login-field">
                            <label asp-for="Username">Username</label>
                            <div class="login-input-wrap">
                                <i class="fas fa-user"></i>
                                <input asp-for="Username" class="login-input" autocomplete="username" placeholder="Enter your username">
                            </div>
                        </div>

                        <div class="login-field">
                            <label asp-for="Password">Password</label>
                            <div class="login-input-wrap">
                                <i class="fas fa-lock"></i>
                                <input asp-for="Password" type="password" class="login-input" autocomplete="current-password" placeholder="Enter your password">
                            </div>
                        </div>

                        <div class="login-remember">
                            <label class="login-checkbox" for="remember">
                                <input type="checkbox" id="remember">
                                <span>Remember</span>
                            </label>
                        </div>

                        <button type="submit" class="login-submit">
                            Sign in
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>
</body>
</html>


@page
@model ZkbioDashboard.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Log in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ZKBIO CVSecurity | Log in</title>
    <link rel="icon" type="image/png" href="~/images/logo/favicon_cv.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        :root {
            --login-bg-top: #0f172a;
            --login-bg-bottom: #1e293b;
            --login-surface: rgba(255, 255, 255, 0.94);
            --login-surface-border: rgba(255, 255, 255, 0.28);
            --login-accent: #15803d;
            --login-accent-dark: #166534;
            --login-accent-soft: rgba(34, 197, 94, 0.16);
            --login-text: #0f172a;
            --login-muted: #64748b;
            --login-shadow: 0 30px 70px rgba(15, 23, 42, 0.38);
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            min-height: 100%;
            margin: 0;
            font-family: "Manrope", sans-serif;
            color: var(--login-text);
            background:
                radial-gradient(circle at top left, rgba(34, 197, 94, 0.32), transparent 34%),
                radial-gradient(circle at right center, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, var(--login-bg-top), var(--login-bg-bottom));
        }

        body {
            position: relative;
            overflow: hidden;
        }

        body::before,
        body::after {
            content: "";
            position: absolute;
            border-radius: 999px;
            filter: blur(8px);
            opacity: 0.72;
            pointer-events: none;
        }

        body::before {
            top: -140px;
            left: -80px;
            width: 360px;
            height: 360px;
            background: rgba(21, 128, 61, 0.18);
        }

        body::after {
            right: -110px;
            bottom: -160px;
            width: 420px;
            height: 420px;
            background: rgba(59, 130, 246, 0.12);
        }

        .login-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
            position: relative;
            z-index: 1;
        }

        .login-stage {
            width: min(1080px, 100%);
            display: grid;
            grid-template-columns: 1.05fr minmax(360px, 420px);
            border-radius: 28px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: var(--login-shadow);
            backdrop-filter: blur(14px);
        }

        /* Brand panel visual */
        .login-brand-panel {
            position: relative;
            padding: 40px 48px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            background:
                linear-gradient(160deg, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.62)),
                linear-gradient(120deg, rgba(21, 128, 61, 0.25), rgba(14, 116, 144, 0.18));
            color: #f8fafc;
        }

        .login-brand-visual {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 24px 0;
        }

        .login-ring {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(34, 197, 94, 0.25);
            animation: ring-pulse 3.6s ease-out infinite;
        }
        .login-ring:nth-child(1) { width: 100px; height: 100px; animation-delay: 0s;    border-color: rgba(34,197,94,0.55); }
        .login-ring:nth-child(2) { width: 160px; height: 160px; animation-delay: 0.7s;  border-color: rgba(34,197,94,0.3); }
        .login-ring:nth-child(3) { width: 220px; height: 220px; animation-delay: 1.4s;  border-color: rgba(34,197,94,0.18); }
        .login-ring:nth-child(4) { width: 280px; height: 280px; animation-delay: 2.1s;  border-color: rgba(34,197,94,0.08); }

        @@keyframes ring-pulse {
            0%   { transform: scale(0.88); opacity: 0; }
            20%  { opacity: 1; }
            100% { transform: scale(1.06); opacity: 0; }
        }

        .login-brand-icon {
            position: relative;
            z-index: 2;
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(21, 128, 61, 0.22);
            border: 1px solid rgba(34, 197, 94, 0.38);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 40px rgba(34,197,94,0.2);
        }
        .login-brand-icon svg {
            width: 30px;
            height: 30px;
            color: #4ade80;
        }

        .login-brand-footer {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.75rem;
            font-weight: 600;
            color: rgba(148, 163, 184, 0.7);
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }
        .login-brand-footer .dot {
            width: 3px;
            height: 3px;
            border-radius: 50%;
            background: rgba(34,197,94,0.5);
        }

        .login-brand-panel::after {
            content: "";
            position: absolute;
            inset: auto -140px -140px auto;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(34, 197, 94, 0.32), transparent 68%);
        }

        .login-brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px;
        }

        .login-brand-mark img {
            height: 44px;
            width: auto;
        }

        .login-brand-name {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.03em;
        }

        .login-brand-copy h1 {
            margin: 0 0 16px;
            font-size: clamp(2rem, 4vw, 3.15rem);
            line-height: 1.02;
            letter-spacing: -0.05em;
            font-weight: 800;
        }

        .login-brand-copy p {
            margin: 0;
            max-width: 540px;
            color: rgba(226, 232, 240, 0.82);
            font-size: 1rem;
            line-height: 1.75;
        }

        .login-feature-list {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 14px;
            margin-top: 36px;
        }

        .login-feature {
            padding: 16px 18px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .login-feature strong {
            display: block;
            margin-bottom: 6px;
            font-size: 0.92rem;
            font-weight: 700;
        }

        .login-feature span {
            font-size: 0.82rem;
            color: rgba(226, 232, 240, 0.72);
        }

        .login-form-panel {
            padding: 42px 38px 34px;
            background: var(--login-surface);
            display: flex;
            align-items: center;
        }

        .login-form-card {
            width: 100%;
        }

        .login-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 999px;
            background: var(--login-accent-soft);
            color: var(--login-accent-dark);
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .login-form-card h2 {
            margin: 18px 0 8px;
            font-size: 1.95rem;
            line-height: 1.1;
            letter-spacing: -0.04em;
            font-weight: 800;
        }

        .login-form-card .login-subtitle {
            margin: 0 0 28px;
            color: var(--login-muted);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        .login-alert {
            margin-bottom: 18px;
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #b91c1c;
            font-size: 0.88rem;
            font-weight: 600;
        }

        .login-field {
            margin-bottom: 16px;
        }

        .login-field label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #334155;
        }

        .login-input-wrap {
            position: relative;
        }

        .login-input-wrap i {
            position: absolute;
            top: 50%;
            left: 16px;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.95rem;
            z-index: 1;
            pointer-events: none;
        }

        .login-input {
            width: 100%;
            height: 50px;
            border: 1px solid #dbe3ee;
            border-radius: 16px;
            background: #ffffff;
            padding: 0 16px 0 44px;
            font: inherit;
            font-size: 0.95rem;
            color: var(--login-text);
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        }

        .login-input:focus {
            outline: none;
            border-color: rgba(21, 128, 61, 0.52);
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
            transform: translateY(-1px);
        }

        .login-remember {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin: 8px 0 24px;
            color: var(--login-muted);
            font-size: 0.88rem;
        }

        .login-checkbox {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            user-select: none;
        }

        .login-checkbox input {
            width: 16px;
            height: 16px;
            accent-color: var(--login-accent);
        }

        .login-submit {
            width: 100%;
            height: 52px;
            border: 0;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--login-accent), #16a34a);
            color: #fff;
            font: inherit;
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.01em;
            cursor: pointer;
            box-shadow: 0 18px 30px rgba(21, 128, 61, 0.22);
            transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        }

        .login-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 34px rgba(21, 128, 61, 0.28);
            filter: brightness(1.02);
        }

        .login-submit:active {
            transform: translateY(0);
        }

        .login-footer-note {
            margin-top: 18px;
            text-align: center;
            color: var(--login-muted);
            font-size: 0.82rem;
        }

        @@media (max-width: 980px) {
            body {
                overflow: auto;
            }

            .login-shell {
                padding: 22px;
            }

            .login-stage {
                grid-template-columns: 1fr;
            }

            .login-brand-panel {
                padding: 34px 28px;
            }

            .login-feature-list {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .login-shell {
                padding: 14px;
            }

            .login-form-panel,
            .login-brand-panel {
                padding: 24px 20px;
            }

            .login-form-card h2 {
                font-size: 1.65rem;
            }
        }
    </style>
</head>
<body>
    <main class="login-shell">
        <section class="login-stage">
            <div class="login-brand-panel">
                <div class="login-brand-mark">
                    <img src="~/images/logo/logo6600_oversea.png" alt="ZKBIO CVSecurity">
                </div>

                <div class="login-brand-visual">
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-ring"></div>
                    <div class="login-brand-icon">
                        <img src="~/images/logo/favicon_cv.png" alt="" style="width:38px;height:38px;object-fit:contain;">
                    </div>
                </div>

                <div class="login-brand-footer">
                    <span>Access Control</span>
                    <span class="dot"></span>
                    <span>Attendance</span>
                </div>
            </div>

            <div class="login-form-panel">
                <div class="login-form-card">
                    <h2>Sign in</h2>

                    <form method="post">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="login-alert">@Model.ErrorMessage</div>
                        }

                        <div class="login-field">
                            <label asp-for="Username">Username</label>
                            <div class="login-input-wrap">
                                <i class="fas fa-user"></i>
                                <input asp-for="Username" class="login-input" autocomplete="username" placeholder="Enter your username">
                            </div>
                        </div>

                        <div class="login-field">
                            <label asp-for="Password">Password</label>
                            <div class="login-input-wrap">
                                <i class="fas fa-lock"></i>
                                <input asp-for="Password" type="password" class="login-input" autocomplete="current-password" placeholder="Enter your password">
                            </div>
                        </div>

                        <div class="login-remember">
                            <label class="login-checkbox" for="remember">
                                <input type="checkbox" id="remember">
                                <span>Remember</span>
                            </label>
                        </div>

                        <button type="submit" class="login-submit">
                            Sign in
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>
</body>
</html>

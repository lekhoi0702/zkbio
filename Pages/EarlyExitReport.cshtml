@page "/early-exit"
@model ZkbioDashboard.Pages.EarlyExitReportModel
@{
    ViewData["Title"] = "Early Exit";
}

<!-- Hidden export form -->
<form id="exportForm" method="post" action="" style="display:none">
    <input type="hidden" name="date"             id="exportDate" />
    <input type="hidden" name="factory"          id="exportFactory" />
    <input type="hidden" name="bu"               id="exportBU" />
    <input type="hidden" name="thresholdMinutes" id="exportThreshold" />
</form>

@section Scripts {
    <script>
        function openExportModal(type) {
            $('#exportDate')     .val($('[name="ReportDate"]').val());
            $('#exportFactory')  .val($('[name="Factory"]').val());
            $('#exportBU')       .val($('[name="BU"]').val());
            $('#exportThreshold').val($('[name="ThresholdMinutes"]').val());
            $('#exportForm').attr('action', '/api/export/earlyexit/' + type).submit();
        }

        function viewDetails(pin, date, name) {
            ZKBioUi.openTransactionDetails({
                employeeHeader: name + ' (' + pin + ')',
                dateHeader: date,
                url: '?handler=Details',
                requestData: { pin: pin, date: date },
                noRecordsText: 'No records found.',
                errorText: 'Error fetching details.'
            });
        }

        $(function () {
            setTimeout(function() {
                $('#skeleton-loader').hide();
                $('#table-data').fadeIn();
            }, 500);

            ZKBioUi.initSimpleDropdown('#btnExportToggle', '#exportMenuDropdown');
        });
    </script>
}

<section class="content report-shell" style="padding:0; --at-filter-col-min: 160px;">
    <div class="container-fluid px-0 d-flex flex-column" style="height:calc(100vh - 57px); overflow:hidden; gap:0;">

        <div class="at-page-header">
            <h1>Early Exit</h1>
        </div>

        <div class="at-filter-card">
            <div class="at-filter-body">
                <form method="get">
                    <div class="at-filter-grid">
                        <div>
                            <label>Date</label>
                            <input type="date" asp-for="ReportDate" class="form-control" />
                        </div>
                        <div>
                            <label>Factory</label>
                            <select asp-for="Factory" class="form-control">
                                <option value="">-- All --</option>
                                @foreach (var f in Model.Factories)
                                {
                                    <option value="@f">@f</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>BU</label>
                            <select asp-for="BU" class="form-control">
                                <option value="">-- All --</option>
                                @foreach (var bu in Model.BUs)
                                {
                                    <option value="@bu">@bu</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Threshold (min)</label>
                            <input type="number" asp-for="ThresholdMinutes" class="form-control" min="1" max="60" />
                        </div>
                        <div class="at-filter-actions">
                            <button type="submit" class="at-btn at-btn-primary" title="Apply">
                                <i class="fas fa-search"></i>
                            </button>
                            <div class="at-export-wrap">
                                <button type="button" class="at-btn at-btn-secondary" id="btnExportToggle" title="Export">
                                    <i class="fas fa-download"></i>
                                </button>
                                <div class="at-export-menu" id="exportMenuDropdown">
                                    <a href="javascript:void(0)" onclick="openExportModal('excel')">
                                        <i class="far fa-file-excel" style="color:#16a34a;"></i> Excel
                                    </a>
                                    <a href="javascript:void(0)" onclick="openExportModal('pdf')">
                                        <i class="far fa-file-pdf" style="color:#dc2626;"></i> PDF
                                    </a>
                                </div>
                            </div>
                            <a asp-page="./EarlyExitReport" class="at-btn at-btn-ghost" title="Reset">
                                <i class="fas fa-undo-alt"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="at-table-card">
            <div class="at-table-scroll">
                <table class="at-table js-sortable-table">
                    <thead>
                        <tr>
                            <th>Factory</th>
                            <th>BU</th>
                            <th>Dept</th>
                            <th>PIN</th>
                            <th>Name</th>
                            <th>Attend In</th>
                            <th>First Gate Out</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="skeleton-loader">
                        @for (int i = 0; i < 18; i++)
                        {
                            <tr>
                                @for (int j = 0; j < 8; j++) { <td><div class="skeleton skeleton-text"></div></td> }
                            </tr>
                        }
                    </tbody>
                    <tbody id="table-data" style="display:none">
                        @if (Model.Records != null && Model.Records.Any())
                        {
                            foreach (var item in Model.Records)
                            {
                                <tr>
                                    <td>@(item.Factory == "JSG" ? "JIAHSIN" : item.Factory)</td>
                                    <td>@item.BU</td>
                                    <td>@item.DeptName</td>
                                    <td>@item.Pin</td>
                                    <td>@item.FullName</td>
                                    <td>@item.AttendIn?.ToString("HH:mm:ss")</td>
                                    <td>@item.FirstGateOut?.ToString("HH:mm:ss")</td>
                                    <td>
                                        <button type="button" class="at-btn-detail"
                                                onclick="viewDetails('@item.Pin', '@item.Date.ToString("yyyy-MM-dd")', '@item.FullName')">
                                            Details
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="8" class="at-empty">No data found for the selected date.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="at-footer">
                <ul class="at-pagination">
                    <li style="display:flex;align-items:center;padding:0 8px;">
                        <span class="at-footer-total">@Model.TotalCount.ToString("N0") records</span>
                    </li>
                    @{
                        var baseRoute = new Dictionary<string, string> {
                            { "ReportDate",       Model.ReportDate?.ToString("yyyy-MM-dd") ?? "" },
                            { "ThresholdMinutes", Model.ThresholdMinutes.ToString() },
                            { "Factory",          Model.Factory ?? "" },
                            { "BU",               Model.BU ?? "" }
                        };
                    }
                    <li class="@(Model.PageNumber <= 1 ? "disabled" : "")">
                        @{ var prevRoute = new Dictionary<string, string>(baseRoute); prevRoute["PageNumber"] = (Model.PageNumber - 1).ToString(); }
                        <a asp-page="./EarlyExitReport" asp-all-route-data="prevRoute">&laquo;</a>
                    </li>
                    @for (int i = Math.Max(1, Model.PageNumber - 5); i <= Math.Min(Model.TotalPages, Model.PageNumber + 5); i++)
                    {
                        <li class="@(i == Model.PageNumber ? "active" : "")">
                            @{ var currRoute = new Dictionary<string, string>(baseRoute); currRoute["PageNumber"] = i.ToString(); }
                            <a asp-page="./EarlyExitReport" asp-all-route-data="currRoute">@i</a>
                        </li>
                    }
                    <li class="@(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        @{ var nextRoute = new Dictionary<string, string>(baseRoute); nextRoute["PageNumber"] = (Model.PageNumber + 1).ToString(); }
                        <a asp-page="./EarlyExitReport" asp-all-route-data="nextRoute">&raquo;</a>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</section>

@await Html.PartialAsync("_TransactionDetailsModal")

